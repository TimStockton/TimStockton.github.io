    fi
}

# Test 10: Invalid -c option (non-numeric)
test_invalid_threshold() {
    reset_test_state
    export DF_TEST_SCENARIO="low_usage"
    
    local exit_code=0
    "$SCRIPT_TO_TEST" -c "abc" "test@example.com" 2>/dev/null || exit_code=$?
    
    # Script should handle invalid threshold gracefully (implementation dependent)
    # This test documents the behavior rather than enforcing it
    log_test "Invalid threshold handling" "PASS" "Exit code: $exit_code (behavior may vary)"
}

