# Main execution
main() {
    if [[ $# -ne 1 ]]; then
        echo "Usage: $0 <path_to_fs_usage_warning_script>"
        echo
        echo "This script tests the fs_usage_warning program according to"
        echo "the assignment requirements and grading rubric."
        exit 1
    fi
    
    SCRIPT_TO_TEST="$1"
    
    print_color "$BLUE" "File System Usage Warning - Test Suite"
