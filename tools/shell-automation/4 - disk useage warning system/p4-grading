#!/bin/bash

# File System Usage Warning Test Suite
# Tests the fs_usage_warning script according to assignment requirements
# Author: Test Suite Generator
# Usage: ./test_fs_usage_warning.sh <path_to_fs_usage_warning_script>

set -e  # Exit on any error during setup

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Global variables
SCRIPT_TO_TEST=""
TEST_DIR=""
MOCK_DIR=""
ORIGINAL_PATH="$PATH"
TEST_COUNT=0
PASS_COUNT=0
FAIL_COUNT=0

# Test results tracking
declare -a TEST_RESULTS=()

# Function to print colored output
print_color() {
    local color=$1
    local message=$2
    echo -e "${color}${message}${NC}"
}

# Function to log test results
log_test() {
    local test_name="$1"
    local status="$2"
    local details="$3"
    
    TEST_COUNT=$((TEST_COUNT + 1))
    if [[ "$status" == "PASS" ]]; then
        PASS_COUNT=$((PASS_COUNT + 1))
        print_color "$GREEN" "✓ PASS: $test_name"
    else
        FAIL_COUNT=$((FAIL_COUNT + 1))
        print_color "$RED" "✗ FAIL: $test_name"
        if [[ -n "$details" ]]; then
            print_color "$RED" "  Details: $details"
        fi
    fi
    TEST_RESULTS+=("$status: $test_name")
}

# Function to setup test environment
setup_test_env() {
    print_color "$BLUE" "Setting up test environment..."
    
    # Create temporary test directory
    TEST_DIR=$(mktemp -d)
    MOCK_DIR="$TEST_DIR/mock_bin"
    mkdir -p "$MOCK_DIR"
    
    # Create mock df command
    cat > "$MOCK_DIR/df" << 'EOF'
